# === ContentAgent API Keys ===

# Google AI (Gemini 2.5 Pro) — video analysis + QA
GOOGLE_AI_API_KEY=

# fal.ai — unified generation API (Kling, Veo, Wan, Seedance, Sora)
FAL_KEY=

# Anthropic (Claude) — decomposition orchestration
ANTHROPIC_API_KEY=

# OpenAI (optional) — GPT-4o for decomposition, Sora 2 for generation
OPENAI_API_KEY=

# === Defaults ===

# Primary generation model: kling3, veo3, wan2, seedance2, sora2
DEFAULT_GENERATION_MODEL=kling3

# Working directory for intermediate files
WORK_DIR=./work

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
